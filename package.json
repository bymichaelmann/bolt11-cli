{
  "name": "bolt11-cli",
  "version": "2.0.0",
  "description": "Decode and validate Bitcoin Lightning Network BOLT11 payment invoices from the command line",
  "author": "Michael Mann <michaelmann@disroot.org>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/bymichaelmann/bolt11-cli"
  },
  "keywords": [
